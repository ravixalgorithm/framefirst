# Copy to .env.local for local Docker-backed testing.
NODE_ENV=development
API_PORT=3001
PUBLIC_API_URL=http://localhost:3001
TRACK_JS_CDN_URL=http://localhost:3001/track.js

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/framefirst

CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=framefirst
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default

REDIS_URL=redis://localhost:6379
APP_ORIGIN=http://localhost:3000
COLLECT_ALLOWED_ORIGINS=*

# Leave blank for local public /collect testing.
# Protected routes will require Supabase config.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OneSignal server-side push (Settings → Keys & IDs → REST API Key)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
