{
  "name": "@framefirst/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/workers/events.ts",
    "build": "tsc --noEmit -p tsconfig.json && pnpm build:track",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "build:track": "esbuild src/track/index.ts --bundle --format=iife --target=es2018 --minify --outfile=public/track.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@framefirst/db": "workspace:*",
    "@framefirst/types": "workspace:*",
    "@supabase/supabase-js": "^2.75.0",
    "bullmq": "^5.61.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.12",
    "puppeteer": "^25.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
