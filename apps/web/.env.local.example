NEXT_PUBLIC_API_URL=http://localhost:3001
FRAMEFIRST_DEV_SITE_ID=ff_dev_site
# OneSignal Web Push — from dashboard.onesignal.com → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Mobile/PWA testing over HTTPS (ngrok on port 3000):
# 1. pnpm dev:full
# 2. pnpm tunnel:web   (in another terminal — free plan: one tunnel at a time)
# 3. Set NEXT_PUBLIC_APP_URL to your ngrok URL, e.g. https://abc123.ngrok-free.app
# 4. Add the same URL in OneSignal → Settings → Web → Site URL
NEXT_PUBLIC_APP_URL=
