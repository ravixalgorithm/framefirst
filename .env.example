# App
NODE_ENV=development
API_PORT=3001
PUBLIC_API_URL=http://localhost:3001
TRACK_JS_CDN_URL=http://localhost:3001/track.js

# Supabase
# Production should point to Supabase Postgres. Local dev may use the docker Postgres URL below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/framefirst
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=framefirst
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default

# Redis
REDIS_URL=redis://localhost:6379

# Product domains
APP_ORIGIN=http://localhost:3000
COLLECT_ALLOWED_ORIGINS=*

# Anthropic (later AI advisor)
ANTHROPIC_API_KEY=

# Expo push notifications (later mobile alerts)
EXPO_ACCESS_TOKEN=
